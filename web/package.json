{
  "name": "tez-operator-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "边缘云资源运维平台 Web 前端 (M1 资源查询)",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview --port 4173",
