# TEZ Operator 后端环境变量样例
# 拷贝为 .env 并填实际值，.env 已在 .gitignore 中忽略

# ───────── docker-compose（必填，被 docker-compose.yml 引用）─────────
MYSQL_ROOT_PASSWORD=change_me_strong_password
MYSQL_DATABASE=tez_operator

# ───────── 应用 ─────────
TEZ_APP_ENV=local
TEZ_APP_DEBUG=true
TEZ_APP_HOST=0.0.0.0
TEZ_APP_PORT=8000
TEZ_APP_LOG_LEVEL=INFO

# ───────── DB / Redis ─────────
# 本地 docker-compose 默认值
TEZ_DATABASE_URL=mysql+pymysql://tez:tez@127.0.0.1:3306/tez_operator?charset=utf8mb4
TEZ_REDIS_URL=redis://127.0.0.1:6379/0
TEZ_CACHE_DEFAULT_TTL=300

# ───────── Mock 模式（W1 默认全开。切真实模式时改为 false 并填对应 token / base_url）─────────
TEZ_CCDB_MOCK_MODE=true
TEZ_TCUM_MOCK_MODE=true
TEZ_IDCRM_MOCK_MODE=true

# ───────── CCDB ─────────
TEZ_CCDB_BASE_URL=http://ccdb-host:8080
TEZ_CCDB_TOKEN=
TEZ_CCDB_CALLER=tez-operator
TEZ_CCDB_TIMEOUT=5

# CCDB 直查（可选，仅 zone 列表场景）
TEZ_CCDB_DB_HOST=
TEZ_CCDB_DB_PORT=3306
TEZ_CCDB_DB_USER=
TEZ_CCDB_DB_PASSWORD=
TEZ_CCDB_DB_NAME=CCDB4

# ───────── TCUM ─────────
TEZ_TCUM_BASE_URL=http://tcum.example.com
TEZ_TCUM_TOKEN=
TEZ_TCUM_TIMEOUT=5

# ───────── 数全通（IDCRM）─────────
TEZ_IDCRM_BASE_URL=http://idcrm.example.com
TEZ_IDCRM_TOKEN=
TEZ_IDCRM_TIMEOUT=5
