# TEZ Operator 后端环境变量样例
# 拷贝为 .env 并填实际值，.env 已在 .gitignore 中忽略

# ───────── docker-compose（必填，被 docker-compose.yml 引用）─────────
MYSQL_ROOT_PASSWORD=change_me_strong_password
MYSQL_DATABASE=tez_operator

# ───────── 应用 ─────────
TEZ_APP_ENV=local
TEZ_APP_DEBUG=true
TEZ_APP_HOST=0.0.0.0
TEZ_APP_PORT=8000
TEZ_APP_LOG_LEVEL=INFO

# ───────── DB / Redis ─────────
# 本地 docker-compose 默认值
TEZ_DATABASE_URL=mysql+pymysql://tez:tez@127.0.0.1:3306/tez_operator?charset=utf8mb4
TEZ_REDIS_URL=redis://127.0.0.1:6379/0
TEZ_CACHE_DEFAULT_TTL=300
TEZ_CACHE_ZONE_TTL=600

# ───────── 批量查询限流（W3 新增） ─────────
# 同时进行的批量查询数（防止 100 条同时打开 100 个浏览器 tab）
TEZ_BATCH_CONCURRENCY=5
# 单次 batch_search / export 请求接受的最大条数
TEZ_BATCH_MAX_SIZE=100

# ───────── 客户端三态模式 ─────────
# W2 起，每个客户端支持 mock | api | browser 三态（详见 docs/14 § 二）
#   mock    —— 默认；不发请求，返回固定虚构数据
#   api     —— 走官方 OpenAPI（W2 占位，等账号到位再实现）
#   browser —— 走 Playwright 自动化（TCUM 已实现）
TEZ_CMDB_MODE=mock
TEZ_TCUM_MODE=mock
TEZ_IDCRM_MODE=mock

# ───────── 浏览器自动化（TEZ_*_MODE=browser 时使用）─────────
TEZ_BROWSER_PROFILE_DIR=data/playwright-profile
TEZ_BROWSER_HEADLESS=false
TEZ_BROWSER_LOGIN_VALID_DAYS=7
TEZ_BROWSER_PAGE_TIMEOUT_MS=30000
# 默认不忽略 HTTPS 证书错误；仅内网自签证书场景在本地 .env 显式改 true
TEZ_BROWSER_IGNORE_HTTPS_ERRORS=false

# ───────── CMDB ─────────
# 切真实模式时改 TEZ_CMDB_MODE=api 或 browser，并在本地 .env 填内部平台地址
TEZ_CMDB_BASE_URL=http://cmdb.example.com
TEZ_CMDB_TOKEN=
TEZ_CMDB_CALLER=tez-operator
TEZ_CMDB_TIMEOUT=5

# CMDB 直查（可选，仅 zone 列表场景）
TEZ_CMDB_DB_HOST=
TEZ_CMDB_DB_PORT=3306
TEZ_CMDB_DB_USER=
TEZ_CMDB_DB_PASSWORD=
TEZ_CMDB_DB_NAME=CMDB4

# ───────── TCUM ─────────
# 切 browser 模式时把 TEZ_TCUM_MODE=browser 并改 TEZ_TCUM_BASE_URL 为内网真实地址
TEZ_TCUM_BASE_URL=http://tcum.example.com
TEZ_TCUM_TOKEN=
TEZ_TCUM_TIMEOUT=5

# ───────── 数全通（IDCRM）─────────
# IDCRM browser 解析待 W4 真实页面样本补齐；样本到位前保持 TEZ_IDCRM_MODE=mock
TEZ_IDCRM_BASE_URL=http://idcrm.example.com
TEZ_IDCRM_TOKEN=
TEZ_IDCRM_TIMEOUT=5

# ───────── 告警（可选） ─────────
# 企业微信群机器人 webhook URL，留空则告警只 log
TEZ_WECOM_WEBHOOK=
